# EditorConfig — consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{md,rst}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{html,css,js}]
indent_style = space
indent_size = 2
