# Her.axera Backend Environment Configuration
# Copy this file to .env and adjust values for your deployment.
#
# =============================================================================
# Quick Start: minimal config for AX650 board
#   AX_ASR_MODEL_PATH=/opt/models/her-axera/asr
#   AX_TTS_MODEL_PATH=/opt/models/her-axera/tts
#   AX_LLM_API_BASE=http://127.0.0.1:8000/v1
#   DEFAULT_ASR_PROVIDER=ax_asr
#   DEFAULT_LLM_PROVIDER=ax_llm
#   DEFAULT_TTS_PROVIDER=ax_tts
# =============================================================================

# ---- Server ----
APP_NAME=Her Voice Dialogue API
API_PREFIX=/v1
LOG_LEVEL=info

# ---- Default Providers ----
DEFAULT_ASR_PROVIDER=ax_asr
DEFAULT_LLM_PROVIDER=ax_llm
DEFAULT_TTS_PROVIDER=ax_tts
DEFAULT_SPEAKER_PROVIDER=3d_speaker

# ---- Security ----
# Set to true to enable Bearer token authentication on all API endpoints
ENABLE_REQUEST_AUTH=false
API_TOKEN=
# Rate limiting (requests per window per IP)
ENABLE_RATE_LIMIT=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SEC=60

# ---- AX ASR (ax_asr_api wheel) ----
ENABLE_AX_ASR=true
AX_ASR_MODEL_TYPE=sensevoice
AX_ASR_MODEL_PATH=/opt/models/her-axera/asr
AX_ASR_LANGUAGE=zh

# ---- AX TTS (ax_tts_api wheel) ----
ENABLE_AX_TTS=true
AX_TTS_MODEL_PATH=/opt/models/her-axera/tts
AX_TTS_ESPEAK_DATA_PATH=espeak-ng-data
AX_TTS_JIEBA_DICT_PATH=dict
AX_TTS_MAX_SEQ_LEN=96
AX_TTS_TYPE=KOKORO
AX_TTS_VOICE=af_heart
AX_TTS_LANGUAGE=en
AX_TTS_FADE_OUT=0.3
AX_TTS_SAMPLE_RATE=24000

# ---- AX LLM (ax-llm serve) ----
ENABLE_AX_LLM=true
AX_LLM_API_BASE=http://127.0.0.1:8000/v1
AX_LLM_MODEL=ax-llm-default
AX_LLM_HEALTH_URL=http://127.0.0.1:8000/health

# ---- LLM Cloud Fallback (DeepSeek) ----
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- LLM Third-Party (OpenAI Compatible) ----
ENABLE_OPENAI_COMPAT=false
OPENAI_COMPAT_API_BASE=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o

# ---- TTS Cloud Fallback (Edge TTS) ----
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ---- LLM Settings ----
LLM_REQUEST_TIMEOUT=60
ENABLE_FUNCTION_CALLING=false

# ---- Session ----
ENABLE_SESSION_PERSISTENCE=true
SESSION_PERSISTENCE_PATH=sessions.json
SESSION_MAX_MESSAGES=20

# ---- Speaker Recognition (3D-Speaker) ----
ENABLE_SPEAKER_RECOGNITION=false
SPEAKER_REPO_PATH=
SPEAKER_MODEL_DIR=
SPEAKER_PYTHON=python3
SPEAKER_COMMAND=
SPEAKER_TIMEOUT_SEC=60

# ---- Wake Word Detection (openwakeword) ----
ENABLE_WAKE_WORD=false
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# ---- VAD (Silero VAD) ----
SILERO_VAD_SAMPLING_RATE=16000
SILERO_VAD_THRESHOLD=0.45
SILERO_VAD_MIN_SPEECH_MS=350
SILERO_VAD_MIN_SILENCE_MS=700
SILERO_VAD_SPEECH_PAD_MS=300

# ---- Features ----
ENABLE_EMOTION_DETECTION=false
ENABLE_VISION=false
VISION_MODEL=
ENABLE_NOISE_REDUCTION=false

# ---- Limits ----
MAX_AUDIO_SIZE_MB=20
MAX_TTS_TEXT_LENGTH=1000

# ---- Model Download ----
HER_AXERA_MODEL_ROOT=/root/models/her-axera
