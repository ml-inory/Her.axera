APP_NAME=Her Voice Dialogue API
API_PREFIX=/v1
LOG_LEVEL=info
DEFAULT_ASR_PROVIDER=mock_asr
DEFAULT_LLM_PROVIDER=mock_llm
DEFAULT_TTS_PROVIDER=mock_tts
DEFAULT_SPEAKER_PROVIDER=mock_speaker
MAX_AUDIO_SIZE_MB=20
MAX_TTS_TEXT_LENGTH=1000
ENABLE_REQUEST_AUTH=false

# ── DeepSeek LLM Provider ──────────────────────────────────────────
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_REQUEST_TIMEOUT=60

# ── Edge TTS Provider ──────────────────────────────────────────────
# Default voice used by Edge TTS. Available voices include:
# zh-CN-XiaoxiaoNeural, zh-CN-XiaoyiNeural, zh-CN-YunxiNeural,
# zh-CN-YunjianNeural, en-US-JennyNeural, en-US-GuyNeural
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ── Kokoro TTS Provider (AXEngine) ─────────────────────────────────
ENABLE_KOKORO_TTS=false
KOKORO_REPO_PATH=/path/to/kokoro
KOKORO_MODEL_DIR=/path/to/kokoro/axmodel
KOKORO_PYTHON=python3
# KOKORO_COMMAND=  # Custom command override
KOKORO_TIMEOUT_SEC=120

# ── ZipVoice TTS Provider (AXEngine) ──────────────────────────────
ENABLE_ZIPVOICE_TTS=false
ZIPVOICE_REPO_PATH=/path/to/zipvoice
ZIPVOICE_MODEL_DIR=/path/to/zipvoice/axmodel
ZIPVOICE_PYTHON=python3
# ZIPVOICE_COMMAND=  # Custom command override
ZIPVOICE_TIMEOUT_SEC=120

# ── Speaker Recognition (3D-Speaker, AXEngine) ────────────────────
ENABLE_SPEAKER_RECOGNITION=false
SPEAKER_REPO_PATH=/path/to/3D-Speaker
SPEAKER_MODEL_DIR=/path/to/3D-Speaker/axmodel
SPEAKER_PYTHON=python3
# SPEAKER_COMMAND=  # Custom command override
SPEAKER_TIMEOUT_SEC=60

# ── WeNet ONNX ASR Provider ───────────────────────────────────────
# Clone https://github.com/ml-inory/wenet.axera.git and point these
# paths at the repo plus exported ONNX artifacts.
ENABLE_WENET_ASR=false
WENET_REPO_PATH=/path/to/wenet.axera
WENET_ONNX_DIR=/path/to/wenet.axera/onnx_model
WENET_CONFIG_PATH=/path/to/wenet.axera/onnx_model/config.yaml
WENET_VOCAB_PATH=/path/to/units.txt
WENET_MODE=ctc_prefix_beam_search
WENET_ONLINE=false
WENET_OFFLINE_SEQ_LEN=1024
WENET_DECODER_LEN=32
WENET_ORT_PROVIDERS=CPUExecutionProvider
# WENET_CALIB_DATA_PATH=/path/to/calibration_dataset

# ── Silero VAD ─────────────────────────────────────────────────────
# Used when ASR transcriptions are called with enable_vad=true.
SILERO_VAD_SAMPLING_RATE=16000
SILERO_VAD_THRESHOLD=0.45
SILERO_VAD_MIN_SPEECH_MS=350
SILERO_VAD_MIN_SILENCE_MS=700
SILERO_VAD_SPEECH_PAD_MS=300

# ── SenseVoice ASR Provider ───────────────────────────────────────
# From https://huggingface.co/AXERA-TECH/SenseVoice.
# Clone/download the Hugging Face repo and point SENSEVOICE_REPO_PATH to it.
ENABLE_SENSEVOICE_ASR=false
SENSEVOICE_REPO_PATH=/path/to/SenseVoice
SENSEVOICE_PYTHON=python3
SENSEVOICE_LANGUAGE=auto
SENSEVOICE_TIMEOUT_SEC=60
SENSEVOICE_STREAMING=false

# ── FireRedASR-AED ASR Provider ───────────────────────────────────
# Use hf-mirror to clone on restricted networks:
# git clone https://hf-mirror.com/AXERA-TECH/FireRedASR-AED /path/to/FireRedASR-AED
ENABLE_FIREREDASR_ASR=false
FIREREDASR_REPO_PATH=/path/to/FireRedASR-AED
FIREREDASR_MODEL_DIR=/path/to/FireRedASR-AED/axmodel
FIREREDASR_BEAM_SIZE=1
FIREREDASR_NBEST=1
FIREREDASR_DECODE_MAX_LEN=128
FIREREDASR_MAX_AUDIO_SEC=10
